{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rogerchappel.github.io/argvault/cassette.schema.json",
  "title": "ArgVault cassette v1",
  "type": "object",
  "required": ["schemaVersion", "tool", "cwd", "argv", "command", "env", "stdout", "stderr", "exitCode", "durationMs", "fixtures", "redactions", "notes"],
  "properties": {
    "schemaVersion": { "const": "argvault.cassette/v1" },
    "tool": { "const": "argvault" },
    "recordedAt": { "type": "string" },
    "cwd": { "type": "string" },
    "argv": { "type": "array", "items": { "type": "string" } },
    "command": { "type": "string" },
    "env": { "type": "object", "additionalProperties": { "type": "string" } },
    "stdin": { "$ref": "#/$defs/sample" },
    "stdout": { "$ref": "#/$defs/sample" },
    "stderr": { "$ref": "#/$defs/sample" },
    "exitCode": { "type": ["integer", "null"] },
    "signal": { "type": ["string", "null"] },
    "durationMs": { "type": "integer", "minimum": 0 },
    "fixtures": { "type": "array", "items": { "$ref": "#/$defs/fixture" } },
    "redactions": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "sample": {
      "type": "object",
      "required": ["text", "truncated", "bytes"],
      "properties": {
        "text": { "type": "string" },
        "truncated": { "type": "boolean" },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "fixture": {
      "type": "object",
      "required": ["path", "sha256", "bytes"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
